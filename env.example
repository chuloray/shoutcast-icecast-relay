# ── Shoutcast Source ──────────────────────────────────
RELAY_SHOUTCAST_URL=http://your-shoutcast-server:8000

# ── Icecast Destination ──────────────────────────────
RELAY_ICECAST_HOST=icecast
RELAY_ICECAST_PORT=8000
RELAY_ICECAST_MOUNT=/relay
RELAY_ICECAST_USER=source
RELAY_ICECAST_PASSWORD=hackme
RELAY_ICECAST_ADMIN_USER=admin
RELAY_ICECAST_ADMIN_PASSWORD=hackme

# ── Station Info ─────────────────────────────────────
RELAY_ICECAST_NAME=My Station
RELAY_ICECAST_DESCRIPTION=Relayed from Shoutcast
RELAY_ICECAST_GENRE=Various
RELAY_ICECAST_URL=http://localhost

# ── Relay Settings ───────────────────────────────────
RELAY_RECONNECT_DELAY=5
RELAY_WEB_PORT=8080
